@model SFA.DAS.FAT.Web.Models.Shared.ContactDetailsViewModel

@*  Contact this training provider *@
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

        <h3 class="govuk-heading-m govuk-!-margin-bottom-3">
            Contact this training provider
        </h3>
        <dl class="govuk-summary-list">
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">
                    Registered address
                </dt>
                <dd class="govuk-summary-list__value">
                    <span asp-show="@Model.HasRegisteredAddress">@Model.RegisteredAddress</span>
                    <span asp-show="@(!Model.HasRegisteredAddress)">-</span>
                </dd>
            </div>
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">
                    Email
                </dt>
                <dd class="govuk-summary-list__value">
                    <a asp-show="@Model.HasEmail" href="mailto:@Model.Email" class="govuk-link">@Model.Email</a>
                    <span asp-show="@(!Model.HasEmail)">-</span>
                </dd>
            </div>
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">
                    Telephone
                </dt>
                <dd class="govuk-summary-list__value">
                    <span asp-show="@Model.HasPhoneNumber">@Model.PhoneNumber</span>
                    <span asp-show="@(!Model.HasPhoneNumber)">-</span>
                </dd>
            </div>
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">
                    Website
                </dt>
                <dd class="govuk-summary-list__value">
                    <a asp-show="@Model.HasWebsite" href="@Model.Website" target="_blank" class="govuk-link">@Model.Website</a>
                    <span asp-show="@(!Model.HasWebsite)">-</span>
                </dd>
            </div>
        </dl>
    </div>
</div>
