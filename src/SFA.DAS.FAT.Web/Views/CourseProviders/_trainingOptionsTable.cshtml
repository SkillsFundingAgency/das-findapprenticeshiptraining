@using SFA.DAS.FAT.Domain.Courses
@using SFA.DAS.FAT.Web.Models
@using TrainingOptionsTableViewModel = SFA.DAS.FAT.Web.Models.CourseProviders.TrainingOptionsTableViewModel
@model SFA.DAS.FAT.Web.Models.CourseProviders.TrainingOptionsTableViewModel

<table class="govuk-table">
    <thead class="govuk-table__head">
        <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header das-table-cell-width-35">Training option</th>
            <th scope="col" class="govuk-table__header das-table-cell-width-65">Location</th>
        </tr>
    </thead>

    <tbody class="govuk-table__body">

        <tr asp-show="@Model.ShowOnlineOption" class="govuk-table__row">
                <th scope="row" class="govuk-table__header">
                    <p class="govuk-!-font-weight-bold govuk-body govuk-!-margin-bottom-1 govuk-!-margin-top-2">
                        Online
                    </p>
                </th>
                <td class="govuk-table__cell">
                    <p class="govuk-body govuk-!-margin-top-2">
                        @TrainingOptionsTableViewModel.OnlineTraining
                    </p>
                </td>
            </tr>

        <tr asp-show="@Model.ShowLearnerWorkplaceOption" class="govuk-table__row">
                <th scope="row" class="govuk-table__header">
                    <p class="govuk-!-font-weight-bold govuk-body govuk-!-margin-bottom-1 govuk-!-margin-top-2">
                        At learner's workplace
                    </p>
                </th>
                <td class="govuk-table__cell">
                    @if (string.IsNullOrWhiteSpace(Model.Location))
                    {
                        <p class="govuk-body govuk-!-margin-top-2">
                            @Model.AtLearnerWorkplaceWithNoLocationDisplayMessage
                        </p>
                    }
                    else
                    {
                        @if (Model.HasMatchingRegionalLocationOrNational)
                        {
                            <p class="govuk-body govuk-!-margin-top-2">
                                @TrainingOptionsTableViewModel.AtLearnerWorkplaceWithLocationMatchingRegionalOrNational
                            </p>
                        }
                        else
                        {
                            <p class="govuk-body govuk-!-margin-top-2">
                                @TrainingOptionsTableViewModel.AtLearnerWorkplaceWithLocationNotMatchingRegional
                            </p>
                        }
                    }
                </td>
            </tr>

        <tr asp-show="@Model.ShowProviderOption" class="govuk-table__row">
                <th scope="row" class="govuk-table__header">
                    <p class="govuk-!-font-weight-bold govuk-body govuk-!-margin-bottom-1 govuk-!-margin-top-2">
                        At training provider’s location
                    </p>
                </th>
                <td class="govuk-table__cell">
                    @if (string.IsNullOrWhiteSpace(Model.Location))
                    {
                        @if (Model.HasMultipleProviderLocations)
                        {
                            <p class="govuk-body govuk-!-margin-top-2">@TrainingOptionsTableViewModel.AtProviderPlaceWithMultipleLocations</p>
                            <details class="govuk-details">
                                <summary class="govuk-details__summary">
                                    <span class="govuk-details__summary-text">
                                        @TrainingOptionsTableViewModel.ViewAllProviderLocations
                                    </span>
                                </summary>
                                <div class="govuk-details__text">
                                    <ul class="govuk-list govuk-list--bullet">
                                        @foreach (LocationModel location in Model.ProviderLocations)
                                        {
                                            <li>
                                                @location.FormatAddress()
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </details>
                        }
                        else
                        {
                            <p class="govuk-body govuk-!-margin-top-2">
                                @Model.ProviderLocations[0].FormatAddress()
                            </p>
                        }
                    }
                    else
                    {
                        <p class="govuk-body govuk-!-margin-top-2">
                            @TrainingOptionsTableViewModel.ProviderClosestLocationWithLocation <strong>@Model.ClosestProviderLocationDistanceDisplay @TrainingOptionsTableViewModel.MilesAway</strong> @Model.ClosestProviderLocationAddress
                        </p>
                        if (Model.HasMultipleProviderLocations)
                        {
                            <details class="govuk-details">
                                <summary class="govuk-details__summary">
                                    <span class="govuk-details__summary-text">
                                        @TrainingOptionsTableViewModel.ViewAllProviderLocations
                                    </span>
                                </summary>
                                <div class="govuk-details__text">
                                    <ul class="govuk-list govuk-list--bullet">
                                        @foreach (LocationModel location in Model.ProviderLocations)
                                        {
                                            <li>
                                                <strong>@location.CourseDistance.ToString("0.0") @TrainingOptionsTableViewModel.MilesAway</strong> @location.FormatAddress()
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </details>
                        }
                    }
                </td>
            </tr>

        <tr asp-show="@Model.ShowBlockReleaseOption" class="govuk-table__row">
                <th scope="row" class="govuk-table__header govuk-!-padding-right-3">
                    <p class="govuk-!-font-weight-bold govuk-body govuk-!-margin-bottom-1 govuk-!-margin-top-2">
                        Block release
                    </p>
                    <p class="govuk-body-m das-hint-colour">
                        @TrainingOptionsTableViewModel.BlockReleaseHint
                    </p>
                </th>

                <td class="govuk-table__cell">
                    @if (Model.HasMultipleBlockReleaseLocations)
                    {
                        if (string.IsNullOrWhiteSpace(Model.Location))
                        {
                            <p class="govuk-body govuk-!-margin-top-2">@TrainingOptionsTableViewModel.BlockReleaseMultipleLocations</p>
                        }
                        else
                        {
                            <p class="govuk-body govuk-!-margin-top-2">
                                <strong>@Model.ClosestBlockReleaseLocationDistanceDisplay @TrainingOptionsTableViewModel.MilesAway</strong> @TrainingOptionsTableViewModel.ToClosestLocation @Model.ClosestBlockReleaseLocation.FormatAddress()
                            </p>
                        }

                        <details class="govuk-details">
                            <summary class="govuk-details__summary">
                                <span class="govuk-details__summary-text">
                                    @TrainingOptionsTableViewModel.ViewAllBlockReleaseLocations
                                </span>
                            </summary>
                            <div class="govuk-details__text">
                                <ul class="govuk-list govuk-list--bullet">
                                    @foreach (LocationModel location in Model.BlockReleaseLocations)
                                    {
                                        @if (string.IsNullOrWhiteSpace(Model.Location))
                                        {
                                            <li>
                                                @location.FormatAddress()
                                            </li>
                                        }
                                        else
                                        {
                                            <li>
                                                <strong>@location.CourseDistance.ToString("0.0") miles</strong> to @location.FormatAddress()
                                            </li>
                                        }
                                    }
                                </ul>
                            </div>
                        </details>
                    }
                    else
                    {
                        if (string.IsNullOrWhiteSpace(Model.Location))
                        {
                            <p class="govuk-body govuk-!-margin-top-2">@Model.BlockReleaseLocations[0].FormatAddress()</p>
                        }
                        else
                        {
                            <p class="govuk-body govuk-!-margin-top-2">
                                <strong>@Model.ClosestBlockReleaseLocationDistanceDisplay @TrainingOptionsTableViewModel.MilesAway</strong> @TrainingOptionsTableViewModel.ToClosestLocation @Model.ClosestBlockReleaseLocation.FormatAddress()
                            </p>
                        }
                    }
                </td>
            </tr>

        <tr asp-show="@Model.ShowDayReleaseOption" class="govuk-table__row">
                <th scope="row" class="govuk-table__header govuk-!-padding-right-3">
                    <p class="govuk-!-font-weight-bold govuk-body govuk-!-margin-bottom-1 govuk-!-margin-top-2">
                        Day release
                    </p>
                    <p class="govuk-body-m das-hint-colour">
                        @TrainingOptionsTableViewModel.DayReleaseHint
                    </p>
                </th>

                <td class="govuk-table__cell">
                    @if (Model.HasMultipleDayReleaseLocations)
                    {
                        if (string.IsNullOrWhiteSpace(Model.Location))
                        {
                            <p class="govuk-body govuk-!-margin-top-2">@TrainingOptionsTableViewModel.DayReleaseMultipleLocations</p>
                        }
                        else
                        {
                            <p class="govuk-body govuk-!-margin-top-2">
                                <strong>@Model.ClosestDayReleaseLocationDistanceDisplay @TrainingOptionsTableViewModel.MilesAway</strong> @TrainingOptionsTableViewModel.ToClosestLocation @Model.ClosestDayReleaseLocation.FormatAddress()
                            </p>
                        }

                        <details class="govuk-details">
                            <summary class="govuk-details__summary">
                                <span class="govuk-details__summary-text">
                                    @TrainingOptionsTableViewModel.ViewAllDayReleaseLocations
                                </span>
                            </summary>
                            <div class="govuk-details__text">
                                <ul class="govuk-list govuk-list--bullet">
                                    @foreach (LocationModel location in Model.DayReleaseLocations)
                                    {
                                        @if (string.IsNullOrWhiteSpace(Model.Location))
                                        {
                                            <li>
                                                @location.FormatAddress()
                                            </li>
                                        }
                                        else
                                        {
                                            <li>
                                                <strong>@location.CourseDistance.ToString("0.0") miles</strong> to @location.FormatAddress()
                                            </li>
                                        }
                                    }
                                </ul>
                            </div>
                        </details>
                    }
                    else
                    {
                        if (string.IsNullOrWhiteSpace(Model.Location))
                        {
                            <p class="govuk-body govuk-!-margin-top-2">@Model.DayReleaseLocations[0].FormatAddress()</p>
                        }
                        else
                        {
                            <p class="govuk-body govuk-!-margin-top-2">
                                <strong>@Model.ClosestDayReleaseLocationDistanceDisplay @TrainingOptionsTableViewModel.MilesAway</strong> @TrainingOptionsTableViewModel.ToClosestLocation @Model.ClosestDayReleaseLocation.FormatAddress()
                            </p>
                        }
                    }
                </td>
            </tr>
    
    </tbody>
</table>
